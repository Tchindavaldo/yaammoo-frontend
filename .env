EXPO_PUBLIC_DISABLE_GOOGLE_AUTH=false
# Remplace par le vrai UUID EAS depuis expo.dev → Project Settings → Project ID
EXPO_PUBLIC_EAS_PROJECT_ID=44bc7644-3f94-439e-8c1f-896bfb55b526
EAS_SKIP_AUTO_FINGERPRINT=1
# Active le fallback Expo Push Token si le token natif (APNs/FCM) échoue
# Par défaut désactivé : on utilise uniquement APNs direct (.p8) + FCM natif
EXPO_PUBLIC_USE_EXPO_PUSH=false
